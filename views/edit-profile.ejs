<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Perfil | Cidade Sorriso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Poppins:wght@700&display=swap" rel="stylesheet">
    <style>
        body { background-color: #f4f4f4; font-family: 'Inter', sans-serif; }
        .navbar { background-color: #111111; padding: 15px 0; }
        .navbar-brand { color: #f1c40f !important; font-family: 'Poppins', sans-serif; font-weight: bold; }
    </style>
</head>
<body>
    <%
        const profilePictureUrl = user.profilePicture && !user.profilePicture.startsWith('default-profile')
            ? '/uploads/avatares/' + user.profilePicture
            : '/images/default-profile.svg';
    %>

    <nav class="navbar navbar-expand-lg shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/timeline">CIDADE SORRISO</a>
            <div class="ms-auto d-flex align-items-center">
                <img src="<%= profilePictureUrl %>" 
                     width="32" height="32" class="rounded-circle me-3" style="object-fit: cover; border: 2px solid #f1c40f;">
                <a class="btn btn-outline-light btn-sm" href="/logout">Sair</a>
            </div>
        </div>
    </nav>

    <main class="container py-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <% if (messages.error && messages.error.length > 0) { %>
                    <div class="alert alert-danger shadow-sm border-0"><%= messages.error %></div>
                <% } %>
                <% if (messages.success && messages.success.length > 0) { %>
                    <div class="alert alert-success shadow-sm border-0"><%= messages.success %></div>
                <% } %>

                <div class="card shadow" style="border: none; border-radius: 15px;">
                    <div class="card-header text-center text-white" style="background-color: #111111; padding: 25px; border-radius: 15px 15px 0 0;">
                        <h3 class="fw-bold mb-0" style="font-family: 'Poppins', sans-serif;">Meu Perfil</h3>
                        <p class="text-white-50 small mb-0">Atualize sua ficha de membro</p>
                    </div>
                    
                    <div class="card-body p-4 p-md-5">
                        <form action="/profile/edit" method="POST" enctype="multipart/form-data">

                            <div class="text-center mb-4">
                                <div class="position-relative d-inline-block">
                                    <img src="<%= profilePictureUrl %>"
                                        id="imgPreview" class="rounded-circle border shadow-sm mb-2" 
                                        width="120" height="120" style="object-fit: cover;">
                                    
                                    <label for="profilePicture" class="btn position-absolute bottom-0 end-0 rounded-circle shadow d-flex align-items-center justify-content-center"
                                        style="width: 35px; height: 35px; background-color: #f1c40f; color: #111; cursor: pointer;">
                                        <i class="bi bi-camera-fill"></i>
                                    </label>
                                    <input type="file" class="d-none" id="profilePicture" name="profilePicture" accept="image/*" onchange="previewImage(this)">
                                </div>
                                <p class="small text-muted mt-2">Toque na câmera para mudar sua foto oficial</p>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Nome de Usuário</label>
                                    <input type="text" class="form-control bg-light" value="<%= user.username %>" disabled>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">E-mail de Cadastro</label>
                                    <input type="text" class="form-control bg-light" value="<%= user.email %>" disabled>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="fullName" class="form-label fw-bold">Nome Completo</label>
                                <input type="text" class="form-control" id="fullName" name="fullName" value="<%= user.fullName || '' %>">
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6 mb-3">
                                    <label for="dataNascimento" class="form-label fw-bold">Data de Nascimento</label>
                                    <input type="date" class="form-control" id="dataNascimento" name="dataNascimento" value="<%= user.dataNascimento || '' %>">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="unidade" class="form-label fw-bold">Unidade</label>
                                    <input type="text" class="form-control" id="unidade" name="unidade" value="<%= user.unidade || '' %>">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="bio" class="form-label fw-bold">Biografia do Desbravador</label>
                                <textarea class="form-control" id="bio" name="bio" rows="3" maxlength="255" placeholder="Fale sobre sua jornada no clube..."><%= user.bio || '' %></textarea>
                                <div class="text-end small text-muted mt-1" id="charCount">0/255</div>
                            </div>

                            <button type="submit" class="btn w-100 fw-bold" style="background-color: #111111; color: #f1c40f; padding: 12px; border-radius: 8px;">Salvar Alterações</button>
                            <div class="text-center mt-3">
                                <a href="/timeline" class="text-muted small text-decoration-none"><i class="bi bi-arrow-left"></i> Voltar para a Linha do Tempo</a>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        const bio = document.getElementById('bio');
        const charCount = document.getElementById('charCount');
        bio.addEventListener('input', () => charCount.textContent = `${bio.value.length}/255`);
        charCount.textContent = `${bio.value.length}/255`;
    </script>
</body>
</html>
