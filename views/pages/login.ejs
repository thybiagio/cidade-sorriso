<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
                
                <div class="card-header text-center text-white py-4" style="background-color: #111111;">
                    <h3 class="fw-bold mb-0" style="font-family: 'Poppins', sans-serif;">
                        CIDADE <span class="text-warning">SORRISO</span>
                    </h3>
                    <p class="text-muted small mb-0 mt-1">Acesso à Área do Membro</p>
                </div>

                <div class="card-body p-4 bg-light">
                    <form action="/login" method="POST">
                        
                        <div class="mb-4">
                            <label for="email" class="form-label fw-bold text-muted small text-uppercase" style="letter-spacing: 1px;">E-mail Registado</label>
                            <input type="email" class="form-control form-control-lg fs-6 bg-white" id="email" name="email"
                                   placeholder="Digite o seu e-mail" required>
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label fw-bold text-muted small text-uppercase" style="letter-spacing: 1px;">Senha</label>
                            <input type="password" class="form-control form-control-lg fs-6 bg-white" id="password" name="password"
                                   placeholder="Sua senha secreta" required>
                        </div>

                        <div class="d-grid gap-2 mt-2">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow-sm text-dark" style="border-radius: 8px;">
                                Entrar no Clube
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer text-center bg-white py-3 border-0">
                    <p class="text-muted mb-0 small">Ainda não tens ficha? <a href="/register" class="text-warning fw-bold text-decoration-none">Criar Conta</a></p>
                </div>
                
            </div>
        </div>
    </div>
</div>