<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0" style="font-family: 'Poppins', sans-serif;">Linha do Tempo</h4>
                <a href="/upload" class="btn btn-warning fw-bold btn-sm rounded-pill px-3 shadow-sm">
                    <i class="bi bi-camera me-1"></i> Nova Foto
                </a>
            </div>

            <% if (posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <div class="card shadow-sm mb-4" style="border-radius: 12px; border: none; overflow: hidden;">
                        
                        <div class="card-header bg-white d-flex align-items-center py-3 border-0">
                            <a href="/profile/<%= post.User.username %>" class="d-flex align-items-center text-decoration-none text-dark w-100">
                                <img src="<%= post.User.profilePicture && post.User.profilePicture !== 'default-profile.png' ? '/uploads/avatares/' + post.User.profilePicture : '/images/default-profile.png' %>" 
                                     class="rounded-circle me-3 border border-warning" width="45" height="45" style="object-fit: cover;">
                                <div>
                                    <h6 class="mb-0 fw-bold"><%= post.User.fullName || post.User.username %></h6>
                                    <small class="text-muted">
                                        <i class="bi bi-geo-alt-fill text-warning"></i> 
                                        Unidade <%= post.User.unidade || 'Sem Unidade' %>
                                    </small>
                                </div>
                            </a>
                            <small class="text-muted ms-auto text-nowrap"><%= new Date(post.createdAt).toLocaleDateString('pt-BR') %></small>
                        </div>

                        <div id="carousel-<%= post.id %>" class="carousel slide" data-bs-ride="false">
                            <div class="carousel-inner bg-dark">
                                <% post.images.forEach((img, index) => { %>
                                    <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                                        <img src="/uploads/timeline/<%= img %>" class="d-block w-100" style="aspect-ratio: 4/5; object-fit: contain;">
                                    </div>
                                <% }); %>
                            </div>
                            <% if (post.images.length > 1) { %>
                                <button class="carousel-control-prev" type="button" data-bs-target="#carousel-<%= post.id %>" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carousel-<%= post.id %>" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                </button>
                            <% } %>
                        </div>

                        <div class="card-body">
                            <h5 class="fw-bold mb-1"><%= post.title %></h5>
                            <% if (post.description) { %>
                                <p class="card-text text-muted mb-3"><%= post.description %></p>
                            <% } %>
                            <div class="d-flex align-items-center mt-2">
                                <button class="btn btn-light border me-2 rounded-pill fw-bold text-muted">
                                    <i class="bi bi-heart me-1 text-danger"></i> <%= post.likes || 0 %>
                                </button>
                            </div>
                        </div>

                    </div>
                <% }); %>
            <% } else { %>
                <div class="text-center p-5 bg-white shadow-sm" style="border-radius: 15px;">
                    <i class="bi bi-images text-muted mb-3" style="font-size: 4rem;"></i>
                    <h5 class="fw-bold" style="font-family: 'Poppins', sans-serif;">Nenhuma lembrança partilhada</h5>
                    <p class="text-muted">O álbum do clube está vazio. Seja o primeiro a publicar um momento!</p>
                    <a href="/upload" class="btn btn-warning mt-3 rounded-pill fw-bold shadow-sm">Criar Publicação</a>
                </div>
            <% } %>

        </div>
    </div>
</div>