<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm mb-5 border-0" style="border-radius: 20px; overflow: hidden;">
                <div class="bg-warning" style="height: 100px;"></div>
                <div class="card-body text-center position-relative pb-5">
                    <img src="/uploads/avatares/<%= profileUser.profilePicture %>" 
                         class="rounded-circle border border-5 border-white bg-white shadow-sm" 
                         style="width: 140px; height: 140px; object-fit: cover; margin-top: -70px;">
                    
                    <h3 class="fw-bold mt-3 mb-0"><%= profileUser.fullName %></h3>
                    
                    <div class="d-flex align-items-center justify-content-center mt-2 gap-2">
                        <span class="badge bg-dark text-warning px-3 py-2 fs-6 rounded-pill"><%= profileUser.cargo %></span>
                        <% if (profileUser.unidade) { %>
                            <div class="d-flex align-items-center bg-light border px-3 py-1 rounded-pill shadow-sm">
                                <img src="/images/unidades/<%= profileUser.unidade.toLowerCase() %>.png" 
                                     onerror="this.src='/images/logo-desbravadores.png'" width="20" height="20" class="me-2">
                                <span class="fw-bold text-muted small">Unidade <%= profileUser.unidade %></span>
                            </div>
                        <% } %>
                    </div>

                    <div class="mt-4 p-4 bg-light rounded-4 mx-md-5">
                        <h6 class="fw-bold text-muted text-uppercase mb-3 small" style="letter-spacing: 2px;">Investiduras</h6>
                        <div class="d-flex justify-content-center flex-wrap gap-3">
                            <% 
                            const classesDict = {
                                'Amigo': { color: '#4472c4', shape: '50%' }, 'Amigo da Natureza': { color: '#4472c4', shape: '8px' },
                                'Companheiro': { color: '#c00000', shape: '50%' }, 'Companheiro de Excursionismo': { color: '#c00000', shape: '8px' },
                                'Explorador': { color: '#548235', shape: '50%' }, 'Explorador de Campo e Bosque': { color: '#548235', shape: '8px' },
                                'Guia': { color: '#ffc000', shape: '50%' }, 'Guia de Exploração': { color: '#ffc000', shape: '8px' }
                            };
                            %>
                            <% if (profileUser.classes && profileUser.classes.length > 0) { %>
                                <% profileUser.classes.forEach(classe => { 
                                    const style = classesDict[classe] || { color: '#111', shape: '50%' };
                                %>
                                    <div title="<%= classe %>" style="width: 42px; height: 42px; background-color: <%= style.color %>; border-radius: <%= style.shape %>; border: 2px solid white; box-shadow: 0 3px 6px rgba(0,0,0,0.2); position: relative;">
                                        <div style="width: 100%; height: 50%; background: linear-gradient(rgba(255,255,255,0.3), transparent); border-radius: <%= style.shape %> <%= style.shape %> 0 0;"></div>
                                    </div>
                                <% }); %>
                            <% } else { %><p class="text-muted small">Sem investiduras registadas.</p><% } %>
                        </div>
                    </div>
                    <% if (isOwner) { %>
                        <a href="/profile/edit" class="btn btn-outline-dark rounded-pill px-5 fw-bold mt-4 shadow-sm">Alterar Foto</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>