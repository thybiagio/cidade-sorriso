<div class="container my-5">
    <%
        const rawClasses = profileUser.classes;
        let investedClasses = [];

        if (Array.isArray(rawClasses)) {
            investedClasses = rawClasses;
        } else if (typeof rawClasses === 'string' && rawClasses.trim()) {
            try {
                const parsedClasses = JSON.parse(rawClasses);
                investedClasses = Array.isArray(parsedClasses) ? parsedClasses : rawClasses.split(',');
            } catch (error) {
                investedClasses = rawClasses.split(',');
            }
        }

        investedClasses = investedClasses
            .map(classe => String(classe).trim())
            .filter(Boolean);

        const profilePictureUrl = profileUser.profilePicture && !profileUser.profilePicture.startsWith('default-profile')
            ? '/uploads/avatares/' + profileUser.profilePicture
            : '/images/default-profile.svg';
    %>
    <div class="row justify-content-center">
        <div class="col-md-10">
            
            <div class="card shadow-sm mb-5" style="border: none; border-radius: 20px; overflow: hidden;">
                <div class="bg-warning" style="height: 120px;"></div>
                
                <div class="card-body text-center position-relative pb-5">
                    <img src="<%= profilePictureUrl %>" 
                         alt="<%= profileUser.username %>" 
                         class="rounded-circle border border-5 border-white bg-white" 
                         style="width: 150px; height: 150px; object-fit: cover; margin-top: -85px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                    
                    <h3 class="fw-bold mt-3 mb-0" style="font-family: 'Poppins', sans-serif;"><%= profileUser.fullName || profileUser.username %></h3>
                    <p class="text-muted mb-2">@<%= profileUser.username %></p>
                    
                    <div class="d-flex align-items-center justify-content-center mt-2 gap-2">
                        <span class="badge bg-dark text-warning px-3 py-2 fs-6 rounded-pill"><%= profileUser.cargo || 'Desbravador' %></span>
                        
                        <% if (profileUser.unidade) { %>
                            <div class="d-flex align-items-center bg-light border px-3 py-1 rounded-pill shadow-sm">
                                <img src="/images/unidades/<%= profileUser.unidade.toLowerCase() %>.png" 
                                     onerror="this.src='/images/logo-desbravadores.png'" 
                                     width="24" height="24" class="me-2" style="object-fit: contain;">
                                <span class="fw-bold text-muted">Unidade <%= profileUser.unidade %></span>
                            </div>
                        <% } %>
                    </div>
                    
                    <% if (profileUser.bio) { %>
                        <p class="mt-3 px-md-5 mx-md-5" style="font-size: 1.1rem;"><%= profileUser.bio %></p>
                    <% } %>

                    <div class="mt-4 p-3 bg-light rounded-4 mx-md-5 shadow-inner">
                        <h6 class="fw-bold text-muted text-uppercase mb-3" style="letter-spacing: 1px;">Classes Investidas</h6>
                        <div class="d-flex justify-content-center flex-wrap gap-3">
                            
                            <% 
                            const classesDict = {
                                'Amigo': { color: '#4472c4', shape: '50%' }, 
                                'Amigo da Natureza': { color: '#4472c4', shape: '8px' }, 
                                'Companheiro': { color: '#c00000', shape: '50%' }, 
                                'Companheiro de Excursionismo': { color: '#c00000', shape: '8px' },
                                'Explorador': { color: '#548235', shape: '50%' }, 
                                'Explorador de Campo e Bosque': { color: '#548235', shape: '8px' },
                                'Pioneiro': { color: '#7f7f7f', shape: '50%' }, 
                                'Pioneiro de Novas Fronteiras': { color: '#7f7f7f', shape: '8px' },
                                'Excursionista': { color: '#7030a0', shape: '50%' }, 
                                'Excursionista na Mata': { color: '#7030a0', shape: '8px' },
                                'Guia': { color: '#ffc000', shape: '50%' }, 
                                'Guia de Exploração': { color: '#ffc000', shape: '8px' }
                            };
                            %>

                            <% if (investedClasses.length > 0) { %>
                                <% investedClasses.forEach(classe => { 
                                    const style = classesDict[classe] || { color: '#111', shape: '50%' };
                                %>
                                    <div title="<%= classe %>" 
                                         style="width: 45px; height: 45px; background-color: <%= style.color %>; border-radius: <%= style.shape %>; box-shadow: inset 0 -3px 5px rgba(0,0,0,0.3), 0 3px 5px rgba(0,0,0,0.2); border: 2px solid white; display: flex; align-items: center; justify-content: center; position: relative;">
                                         <div style="width: 100%; height: 50%; background: linear-gradient(rgba(255,255,255,0.4), transparent); border-radius: <%= style.shape %> <%= style.shape %> 0 0; position: absolute; top: 0;"></div>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <span class="text-muted small">Em formação para a primeira investidura.</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-5 mt-4">
                        <div class="text-center">
                            <h4 class="fw-bold mb-0"><%= profileUser.postsCount || 0 %></h4>
                            <small class="text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Lembranças</small>
                        </div>
                        <div class="text-center">
                            <h4 class="fw-bold mb-0"><%= profileUser.followersCount || 0 %></h4>
                            <small class="text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Seguidores</small>
                        </div>
                    </div>

                    <div class="mt-4">
                        <% if (isOwner) { %>
                            <a href="/profile/edit" class="btn btn-dark rounded-pill px-5 fw-bold shadow-sm">Editar Ficha</a>
                        <% } else { %>
                            <button class="btn btn-warning rounded-pill px-5 fw-bold shadow-sm">Seguir Desbravador</button>
                        <% } %>
                    </div>
                </div>
            </div>

            <h4 class="fw-bold mb-4" style="font-family: 'Poppins', sans-serif;">Álbum do Clube</h4>
            <div class="row g-2">
                <% if (profileUser.Posts && profileUser.Posts.length > 0) { %>
                    <% profileUser.Posts.forEach(post => { %>
                        <div class="col-4 col-md-4">
                            <div class="position-relative bg-dark" style="aspect-ratio: 1/1; overflow: hidden; border-radius: 8px;">
                                <img src="/uploads/timeline/<%= post.images[0] %>" class="w-100 h-100" style="object-fit: cover; opacity: 0.9; transition: 0.3s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.9">
                                
                                <% if (post.images.length > 1) { %>
                                    <div class="position-absolute top-0 end-0 p-2">
                                        <i class="bi bi-images text-white fs-5" style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.8));"></i>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-camera fs-1 mb-3"></i>
                        <h5>Nenhuma foto partilhada ainda.</h5>
                    </div>
                <% } %>
            </div>

        </div>
    </div>
</div>
