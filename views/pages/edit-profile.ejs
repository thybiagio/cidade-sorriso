<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
                
                <div class="card-header text-center text-white py-4" style="background-color: #0d121f;">
                    <h4 class="fw-bold mb-0" style="font-family: 'Poppins', sans-serif; letter-spacing: 1px;">
                        FICHA DE <span style="color: #FFC107;">MEMBRO</span>
                    </h4>
                    <p class="text-muted small mb-0 mt-1">Dados Oficiais e Configurações</p>
                </div>

                <div class="card-body p-4 bg-light">
                    <form action="/profile/edit" method="POST" enctype="multipart/form-data">
                        
                        <div class="text-center mb-5">
                            <h6 class="fw-bold text-uppercase text-muted small mb-3">Foto do Perfil</h6>
                            
                            <div class="position-relative d-inline-block">
                                <img src="/uploads/avatares/<%= user.profilePicture %>" 
                                     id="preview" 
                                     class="rounded-circle border border-4 border-warning shadow-sm" 
                                     style="width: 130px; height: 130px; object-fit: cover;">
                                
                                <label for="profilePicture" 
                                       class="btn btn-dark btn-sm rounded-circle position-absolute bottom-0 end-0 p-2 shadow-lg" 
                                       style="width: 38px; height: 38px; cursor: pointer;">
                                    <i class="bi bi-camera-fill text-white"></i>
                                </label>
                                <input type="file" id="profilePicture" name="profilePicture" class="d-none" onchange="previewImage(this)">
                            </div>
                            <p class="text-muted small mt-2">Clique na câmera para alterar sua foto de perfil.</p>
                        </div>

                        <div class="p-3 bg-white border rounded-4 mb-4 shadow-sm">
                            <h6 class="fw-bold text-muted text-uppercase small mb-3" style="letter-spacing: 1px;">Sua Ficha Oficial</h6>
                            
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Nome Completo</label>
                                <input type="text" class="form-control" value="<%= user.fullName %>" readonly style="background-color: #f8f9fa;">
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted">Sua Unidade</label>
                                    <div class="d-flex align-items-center form-control bg-light">
                                        <% if (user.unidade) { %>
                                            <img src="/images/unidades/<%= user.unidade.toLowerCase() %>.png" width="20" height="20" class="me-2" onerror="this.src='/images/logo-desbravadores.png'">
                                            <span class="small fw-bold text-warning"><%= user.unidade %></span>
                                        <% } else { %>
                                            <span class="small text-muted">Sem Unidade</span>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted">Seu Cargo</label>
                                    <input type="text" class="form-control" value="<%= user.cargoClube %>" readonly style="background-color: #f8f9fa;">
                                </div>
                            </div>

                            <div class="alert alert-light border small text-muted mb-0 rounded-3">
                                <i class="bi bi-info-circle me-1 text-warning"></i> 
                                Dados como <strong>Cargo, Unidade e Classes</strong> são de responsabilidade da Secretaria do Clube e só podem ser alterados pelo Painel Administrativo.
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow-sm" style="background-color: #FFC107; color: #0d121f; border: none; border-radius: 10px;">
                                Salvar Foto
                            </button>
                            <a href="/profile/<%= user.username %>" class="btn btn-outline-dark btn-sm rounded-pill text-muted small mt-2">
                                Voltar para o Perfil
                            </a>
                        </div>
                    </form>
                </div>
                
            </div>
        </div>
    </div>
</div>

<script>
// Função para pré-visualizar a imagem antes de salvar
function previewImage(input) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) { $('#preview').attr('src', e.target.result); }
        reader.readAsDataURL(input.files[0]);
    }
}
</script>