<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Linha do Tempo | Cidade Sorriso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Poppins:wght@700&display=swap" rel="stylesheet">
    <style>
        body { background-color: #f4f4f4; font-family: 'Inter', sans-serif; }
        .navbar { background-color: #111111; padding: 15px 0; }
        .navbar-brand { color: #f1c40f !important; font-family: 'Poppins', sans-serif; font-weight: bold; }
    </style>
</head>
<body>
    <%
        const profilePictureUrl = user.profilePicture && !user.profilePicture.startsWith('default-profile')
            ? '/uploads/avatares/' + user.profilePicture
            : '/images/default-profile.svg';
    %>

    <nav class="navbar navbar-expand-lg shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/timeline">CIDADE SORRISO</a>
            
            <div class="ms-auto d-flex align-items-center">
                <span class="text-white me-3 d-none d-md-block">
                    Olá, <strong><%= user.fullName || user.username %></strong> (<%= user.unidade || 'Sem Unidade' %>)
                </span>
                
                <div class="dropdown">
                    <a href="#" class="d-block text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="<%= profilePictureUrl %>" 
                             width="42" height="42" class="rounded-circle" style="object-fit: cover; border: 2px solid #f1c40f; background-color: #333;">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Meu Perfil</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <main class="container my-5 text-center">
        <h2>Sua Linha do Tempo</h2>
        <p class="text-muted">As fotos dos eventos, acampadas e especialidades aparecerão aqui em breve!</p>
        <div class="mt-5 p-5 bg-white rounded shadow-sm">
            <h1 class="text-muted"><i class="bi bi-camera"></i></h1>
            <p>Área de Upload de Imagens em construção...</p>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
