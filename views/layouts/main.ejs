<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Clube Cidade Sorriso</title>
    
    <link rel="icon" type="image/png" href="/images/Cidade_sEscrita.png">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Montserrat:wght@800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        body { 
            font-family: 'Poppins', sans-serif; 
            background-color: #f4f7f6; 
            color: #333;
        }
        /* HEADER PRETO */
        .navbar { 
            background-color: #000 !important;
            border-bottom: 4px solid #FFC107; 
            padding: 0.6rem 0;
        }
        .brand-text {
            font-family: 'Montserrat', sans-serif;
            font-weight: 800;
            letter-spacing: -1px;
            font-size: 2.2rem;
            color: #fff; /* "CIDADE" em Branco */
        }
        .nav-link { 
            color: rgba(255,255,255,0.9) !important;
            font-weight: 600; 
            transition: all 0.3s;
        }
        .nav-link:hover { color: #FFC107 !important; }

        /* BOTÃO ENTRAR (BRANCO) */
        .btn-white {
            background-color: #fff !important;
            color: #000 !important;
            font-weight: 700;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            border: none;
        }
        
        /* BOTÃO SAIR (VERMELHO SÓLIDO) */
        .btn-logout {
            background-color: #dc3545 !important;
            color: #fff !important;
            font-weight: 700;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            border: none;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow-lg">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/images/Cidade_sEscrita.png" alt="Escudo" height="65" class="me-3">
                <span class="brand-text">CIDADE <span style="color: #FFC107;">SORRISO</span></span>
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    
                    <li class="nav-item">
                        <a class="nav-link px-3" href="/timeline">Mural</a>
                    </li>

                    <% if (user) { %>
                        <% const cargosADM = ['Diretor', 'Secretário', 'Diretor associado', 'Pastor']; %>
                        <% if (cargosADM.includes(user.cargoClube)) { %>
                            <li class="nav-item">
                                <a class="nav-link px-3 text-warning fw-bold" href="/admin/membros">
                                    <i class="bi bi-shield-check"></i> ADM
                                </a>
                            </li>
                        <% } %>

                        <li class="nav-item">
                            <a class="nav-link px-3" href="/upload">
                                <i class="bi bi-plus-circle"></i> Postar
                            </a>
                        </li>

                        <li class="nav-item ms-lg-3 me-3">
                            <a href="/profile/<%= user.username %>">
                                <img src="/uploads/avatares/<%= user.profilePicture %>" 
                                     class="rounded-circle border border-2 border-white shadow-sm" 
                                     width="55" height="55" style="object-fit: cover;">
                            </a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="btn-logout btn-sm" href="/logout">Sair</a>
                        </li>

                    <% } else { %>
                        <li class="nav-item">
                            <a class="btn btn-white shadow-sm" href="/login">Entrar</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <% if (messages.success || messages.error) { %>
        <div class="container mt-3">
            <% if (messages.success) { %>
                <div class="alert alert-success border-0 shadow-sm rounded-3">
                    <i class="bi bi-check-circle-fill me-2"></i> <%= messages.success %>
                </div>
            <% } %>
            <% if (messages.error) { %>
                <div class="alert alert-danger border-0 shadow-sm rounded-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= messages.error %>
                </div>
            <% } %>
        </div>
    <% } %>

    <main class="py-4">
        <%- body %>
    </main>

    <footer class="bg-dark text-white py-5 mt-5 border-top border-warning">
        <div class="container text-center">
            <img src="/images/Cidade_sEscrita.png" width="50" class="mb-3">
            <h6 class="fw-bold">CLUBE CIDADE SORRISO</h6>
            <p class="text-muted small">Joinville - Santa Catarina</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>