<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Cidade Sorriso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Poppins:wght@700&display=swap" rel="stylesheet">
</head>

<body style="background-color: var(--amarelo); min-height: 100vh; display: flex; align-items: center;">

    <main class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <% if (messages.error && messages.error.length> 0) { %>
                    <div class="alert alert-danger shadow-sm border-0">
                        <%= messages.error %>
                    </div>
                <% } %>
                <% if (messages.success && messages.success.length> 0) { %>
                    <div class="alert alert-success shadow-sm border-0">
                        <%= messages.success %>
                    </div>
                <% } %>

                <div class="card auth-card" style="border: none; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
                    <div class="auth-header" style="background-color: var(--preto); color: var(--branco); padding: 30px; text-align: center;">
                        <h2 class="fw-bold mb-0" style="font-family: 'Poppins', sans-serif;">Acessar Portal</h2>
                        <p class="small mt-2 text-white-50">Bem-vindo de volta, desbravador!</p>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <form action="/login" method="POST">

                            <div class="mb-3">
                                <label for="login" class="form-label fw-bold">E-mail ou Usuário</label>
                                <input type="text" class="form-control bg-light" id="login" name="login" required>
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label fw-bold">Senha</label>
                                <input type="password" class="form-control bg-light" id="password" name="password" required>
                            </div>

                            <button type="submit" class="btn btn-black w-100 mb-3" style="background-color: var(--preto); color: var(--amarelo); padding: 12px; font-weight: bold; border-radius: 8px; border: none;">
                                Entrar
                            </button>

                            <div class="text-center mt-3">
                                <p class="mb-0 text-muted">Ainda não é membro? <a href="/register" style="color: var(--preto); font-weight: bold;">Cadastre-se</a></p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>