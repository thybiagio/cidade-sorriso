<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cidade Sorriso | <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Poppins:wght@700&display=swap" rel="stylesheet">
</head>

<body>
    <nav class="navbar navbar-expand-lg sticky-top shadow-sm" style="background-color: var(--branco);">
        <div class="container">
            <a class="navbar-brand" href="/" style="font-family: 'Poppins', sans-serif;">
                CIDADE SORRISO
            </a>
            <div class="d-flex ms-auto">
                <a class="btn btn-outline-dark me-2" href="/login">Área do Membro</a>
            </div>
        </div>
    </nav>

    <header id="hero" class="d-flex flex-column justify-content-center align-items-center text-center">
        <div class="container">
            <h1>Cidade Sorriso</h1>
            <p class="lead mb-4">Disciplina, união e propósito</p>
            <a href="#quem-somos" class="btn-black">Conhecer o Clube</a>
        </div>
    </header>

    <section id="quem-somos" class="d-flex flex-column justify-content-center align-items-center text-center">
        <div class="container">
            <h2 class="mb-4">Quem Somos</h2>
            <p class="lead" style="max-width: 800px; margin: 0 auto;">
                Somos um grupo cristão que busca desenvolver disciplina, união e propósito entre jovens, através de organização, convivência e valores que fortalecem o caráter.
            </p>
            <div class="row mt-5">
                <div class="col-md-4 mb-3">
                    <div class="p-4" style="background: var(--fundo-card); border-radius: 10px;">
                        <h4>Disciplina</h4>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="p-4" style="background: var(--fundo-card); border-radius: 10px;">
                        <h4>União</h4>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="p-4" style="background: var(--fundo-card); border-radius: 10px;">
                        <h4>Propósito</h4>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="agenda" class="d-flex flex-column justify-content-center align-items-center">
        <div class="container">
            <h2 class="text-center mb-5">Próximos Eventos</h2>
            <div class="row justify-content-center">
                <div class="col-md-8 mb-3">
                    <div class="evento-card p-3 d-flex align-items-center" style="border-left: 5px solid var(--igreja-biblica);">
                        <div class="me-4 text-center" style="min-width: 80px;">
                            <h3 class="mb-0">17</h3>
                            <small class="text-muted">Maio</small>
                        </div>
                        <div>
                            <h5 class="mb-1">Reunião Regular</h5>
                            <span class="badge" style="background-color: var(--igreja-biblica);">Igreja Bíblica</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-white py-4 text-center">
        <p class="mb-0">&copy; 2026 Clube Cidade Sorriso - Joinville/SC.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>